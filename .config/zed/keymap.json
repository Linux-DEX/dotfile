    // ══════════════════════════════════════════════
    // VISUAL MODE
    // ══════════════════════════════════════════════
    {
        "context": "Editor && vim_mode == visual && !menu",
        "bindings": {
            // > stays in visual mode after indent
            ">": ["workspace::SendKeystrokes", "> g v"],

            // < stays in visual mode after outdent
            "<": ["workspace::SendKeystrokes", "< g v"],

            // fb → format selection
            "f b": "editor::Format",
        },
    },

    // From the editor (normal mode) — toggles the docks
    // {
    //     "context": "Editor && vim_mode == normal && !menu",
    //     "bindings": {
