// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "context": "Editor && (vim_mode == normal || vim_mode == visual)",
        "bindings": {
            "ctrl-j": "workspace::ToggleBottomDock",
        },
    },
    {
        "context": "Editor && vim_mode == insert",
        "bindings": {
            "ctrl-j": "workspace::ToggleBottomDock",
            "ctrl-u": "editor::DeleteToBeginningOfLine",
        },
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-j": "workspace::ToggleBottomDock",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-j": "workspace::ToggleBottomDock",
        },
    },
    {
        "context": "Pane",
        "bindings": {
            "ctrl-tab": "pane::ActivateNextItem",
            "ctrl-shift-tab": "pane::ActivatePreviousItem",
        },
    },
    // ── Autocomplete navigation ──────────────────────────────────
    // Context must include "menu" for completion popups
    {
        "context": "Editor && showing_completions",
        "bindings": {
            "tab": "editor::ContextMenuNext",
            "shift-tab": "editor::ContextMenuPrevious", // was "ContextMenuPrev" — renamed post-March 2025
        },
    },

    // ── Move lines up/down ──────────────────────────────────────
    // shift-alt-j/k conflicts with vim; add vim_mode check
    {
        "context": "Editor && vim_mode == normal",
        "bindings": {
            "shift-alt-j": "editor::MoveLineDown",
            "shift-alt-k": "editor::MoveLineUp",
        },
    },
    {
        "context": "Editor && vim_mode == normal",
        "bindings": {
            "shift-alt-j": "editor::MoveLineDown",
            "shift-alt-k": "editor::MoveLineUp",
        },
    },

    // ── Sidebar <-> Editor focus ────────────────────────────────
    // From ProjectPanel: go back to editor
    {
        "context": "ProjectPanel",
        "bindings": {
            "ctrl-h": "workspace::ActivateNextPane",
        },
    },
    // From Editor: toggle/focus project panel
    {
        "context": "Editor",
        "bindings": {
            "ctrl-l": "project_panel::ToggleFocus",
        },
    },

